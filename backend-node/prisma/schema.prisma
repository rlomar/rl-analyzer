generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  coach
  admin
}

enum RequestStatus {
  pending
  accepted
  rejected
  completed
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests     CoachingRequest[] @relation("UserRequests")
  coachRequest CoachingRequest[] @relation("CoachRequests")

  @@map("users")
}

model CoachingRequest {
  id          String        @id @default(cuid())
  userId      String
  coachId     String?
  rank        String
  problemType String
  description String
  status      RequestStatus @default(pending)
  coachNotes  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user  User  @relation("UserRequests", fields: [userId], references: [id], onDelete: Cascade)
  coach User? @relation("CoachRequests", fields: [coachId], references: [id])

  @@index([userId])
  @@index([coachId])
  @@index([status])
  @@map("coaching_requests")
}
